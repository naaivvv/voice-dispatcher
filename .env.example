# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq (for LangChain)
GROQ_API_KEY=your-groq-key
GROQ_MODEL=llama3-70b-8192

# ElevenLabs (for dispatcher TTS)
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
ELEVENLABS_MODEL_ID=eleven_flash_v2_5
ELEVENLABS_OUTPUT_FORMAT=mp3_22050_32

# LangChain / LangSmith (optional tracing)
LANGCHAIN_API_KEY=your-langchain-api-key

# Server
PORT=3000

# Security
# Use a random base64url-style token so it is valid as a WebSocket subprotocol.
DISPATCHER_CLIENT_TOKEN=replace-with-random-token
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080,https://voice-dispatcher-ui.vercel.app
HTTP_RATE_LIMIT_WINDOW_MS=60000
HTTP_RATE_LIMIT_MAX=60
WS_MAX_CONNECTIONS_PER_IP=5
WS_MESSAGE_RATE_LIMIT_PER_MINUTE=60
WS_AGENT_TURN_LIMIT_PER_MINUTE=10
WS_MAX_JSON_BYTES=16384
